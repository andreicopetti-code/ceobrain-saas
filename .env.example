# --- Supabase (projeto NOVO, separado do de empresas) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# --- Supabase (projeto EMPRESAS — base de CNPJs, somente leitura) ---
NEXT_PUBLIC_EMPRESAS_SUPABASE_URL=https://gzsnxnjmvovqyzjslblh.supabase.co
NEXT_PUBLIC_EMPRESAS_SUPABASE_ANON_KEY=sua_anon_key_empresas_aqui

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Produto ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_...   # R$ 99/mês
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=price_...    # R$ 1.089/ano
NEXT_PUBLIC_TRIAL_DAYS=7
